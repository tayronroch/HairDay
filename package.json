{
  "name": "Hairday",
  "description": "Aplicação Web para Agendamento de corta de cabelo",
  "author": {
    "name": "Tayron Rocha",
    "email": "tayronroch@mail.com"
  },
  "scripts": {
    "server": "json-server --watch server.json --port 3333",
    "build": "webpack",
    "dev": "webpack server",
    "build:dev": "npm run build && npm run dev",
    "lint:check": "npm run lint:prettier:check && npm run lint:eslint:check && npm run lint:secretlint:check",
    "lint:fix": "npm run lint:prettier:fix && npm run lint:eslint:fix",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "lint:eslint:fix": "eslint --fix .",
    "lint:secretlint:check": "secretlint \"**/*\" --secretlintignore .gitignore",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "json-server": "^1.0.0-beta.15"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "commitizen": "^4.3.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.8.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.4",
    "jest": "^30.4.2",
    "npm-check-updates": "^22.2.3",
    "prettier": "^3.3.3",
    "secretlint": "^13.0.2",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
